{
  "name": "@mcpservers/ollama-ocr",
  "version": "0.0.4",
  "description": "MCP server for OCR using Ollama Cloud vision models",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-ollama-ocr": "dist/index.js"
  },
  "author": "bossying",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heltonteixeira/ollama-ocr.git"
  },
  "bugs": {
    "url": "https://github.com/heltonteixeira/ollama-ocr/issues"
  },
  "homepage": "https://github.com/heltonteixeira/ollama-ocr#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ocr",
    "ollama",
    "vision",
    "pdf",
    "text-extraction",
    "ocr-server"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "release": "standard-version",
    "release:first": "standard-version --first-release",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:dry": "standard-version --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "0.1.98",
    "ollama": "0.6.3",
    "p-limit": "7.3.0",
    "pdfjs-dist": "^5.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "25.6.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
